# TimesFM Forecasting — Environment Variables
# Copy this file to .env and fill in your values.
# Usage: cp .env.example .env

# Data source type. Built-in options: "json", "csv"
# Add custom sources via register() in forecast.py
TIMESFM_SOURCE=json

# Path or glob pattern passed to the data source.
# For json/csv: path to the directory containing your data files.
# For a custom source (e.g. Prometheus): your connection URL or endpoint.
TIMESFM_SOURCE_PATH=samples/input

# Forecast horizon in number of steps.
# If unset, defaults to the context length of each series (i.e. forecast as
# many steps as there are historical observations, up to 16384).
# TIMESFM_HORIZON=100

# Percentile for the confidence band.
# Must be a multiple of 10 between 10 and 90 (inclusive).
# Setting P produces an upper band at the Pth percentile and a lower band
# at the (100-P)th percentile — e.g. 90 gives a 10th–90th band.
TIMESFM_PERCENTILE=90

# Directory where output PNG charts and JSON files are written.
# Defaults to output/ inside the project directory.
# TIMESFM_OUTPUT_DIR=/path/to/output
